# Application Environment
APP_ENV=development
APP_DEBUG=false

# API Configuration
API_VERSION=1.0.0
API_BASE_URL=http://localhost/wasteless/api/

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production-min-32-characters-needed
JWT_EXPIRATION=86400

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=wasteless

# File Upload
UPLOAD_DIR=uploads/
MAX_UPLOAD_SIZE=5242880

# Pagination
DEFAULT_LIMIT=20
MAX_LIMIT=100

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_ATTEMPTS=5
RATE_LIMIT_AUTH_WINDOW=3600

# CO2 Calculation Factors
CO2_FACTOR_PLASTIC=2
CO2_FACTOR_PAPER=0.5
CO2_FACTOR_FOOD=1.5
CO2_FACTOR_METAL=3
CO2_FACTOR_GLASS=1
CO2_FACTOR_GENERAL=2
